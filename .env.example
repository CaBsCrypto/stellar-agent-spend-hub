# Stellar testnet real rail boundary.
# Copy to .env locally if you want, but never commit real secrets.

STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PUBLIC_KEY=G...
STELLAR_SECRET_KEY=S...

# Real submission is disabled by default. Leave false for demos and reviews.
STELLAR_SUBMIT_ENABLED=false

# Optional destination for a tiny controlled testnet payment when submit is enabled.
STELLAR_TEST_DESTINATION=G...
STELLAR_TEST_AMOUNT_XLM=0.000001

# Optional public Soroban smart wallet identifiers. Never store seed phrases here.
SOROBAN_SMART_WALLET_CONTRACT_ID=C...
SOROBAN_OWNER_PUBLIC_KEY=G...
SOROBAN_SESSION_PUBLIC_KEY=G...
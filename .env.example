# Stellar testnet real rail boundary.
# Copy to .env locally if needed, but never commit real secrets.

STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PUBLIC_KEY=G...
STELLAR_SECRET_KEY=S...
STELLAR_SUBMIT_ENABLED=false
STELLAR_TEST_DESTINATION=G...
STELLAR_TEST_AMOUNT_XLM=0.000001

# Public Soroban smart wallet identifiers. Never store seed phrases here.
SOROBAN_SMART_WALLET_CONTRACT_ID=C...
SOROBAN_OWNER_PUBLIC_KEY=G...
SOROBAN_SESSION_PUBLIC_KEY=G...
SOROBAN_NATIVE_ASSET_CONTRACT_ID=C...
SOROBAN_TEST_DESTINATION=G...
SOROBAN_TEST_AMOUNT=1
SOROBAN_TRANSFER_NONCE=2
SOROBAN_PROVIDER_ID=browserbase-mcp
SOROBAN_ALLOWED_PROVIDERS=browserbase-mcp,exa-api
SOROBAN_TINY_MAX_AMOUNT=1
SOROBAN_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_ASSET=native

# Runtime: simulated, stellar-testnet-direct, soroban-dry-run, or soroban-testnet-submit.
SPEND_HUB_PAYMENT_RAIL=simulated

# Guarded Sprint 08 endpoint. Keep the real token private and submit disabled normally.
SOROBAN_SUBMIT_ADMIN_TOKEN=replace-locally
SOROBAN_SUBMIT_ENABLED=false
SOROBAN_EXECUTION_DRIVER=dry-run

# Sprint 09 official Stellar MPP Charge seller. Keep disabled until Upstash and
# the testnet recipient are configured. Never deploy MPP_BUYER_SECRET.
MPP_ENABLED=false
MPP_NETWORK=stellar:testnet
MPP_PRICE_USDC=0.01
MPP_STELLAR_RECIPIENT=G...
MPP_SECRET_KEY=replace-with-32-plus-random-characters
MPP_STORE_MODE=memory
MPP_STORE_TTL_SECONDS=2592000
LEGACY_402_ENABLED=false
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-in-vercel-only
# Vercel Marketplace may inject KV_REST_API_URL/TOKEN instead; both are supported.

# Local buyer CLI only. Keep these out of Vercel and committed files.
MPP_RISK_ENDPOINT=http://localhost:4179/api/mpp/stellar-risk
MPP_ALLOWED_ORIGIN=http://localhost:4179
MPP_EXPECTED_RECIPIENT=G...
MPP_MAX_PRICE_USDC=0.01


# Sprint 20 Remote MCP Provider Pilot. Keep the gate closed outside a supervised pilot.
MCP_PILOT_ENABLED=false
MCP_PILOT_API_KEY_HASH=sha256-hex-only
MCP_PILOT_APPROVAL_SECRET=replace-with-32-plus-random-characters
MCP_PILOT_MERCHANT_RECIPIENT=G...
MCP_APP_BASE_URL=https://agente-pagos-stellar.vercel.app

# Local pilot buyer only. Never store the raw API key or buyer secret in Vercel.
MCP_PILOT_API_KEY=replace-locally
MCP_PILOT_BASE_URL=http://localhost:4179
MCP_PILOT_ALLOWED_ORIGIN=http://localhost:4179
MCP_PILOT_CI_CONFIRM=false

# Policy Escrow V2 public testnet configuration.
ESCROW_V2_CONTRACT_ID=C...
ESCROW_V2_OWNER_PUBLIC_KEY=G...
ESCROW_V2_SESSION_PUBLIC_KEY=G...
ESCROW_V2_DESTINATION=G...
ESCROW_V2_ASSET_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
ESCROW_V2_PER_PAYMENT_LIMIT=1
ESCROW_V2_TOTAL_LIMIT=2
ESCROW_V2_AMOUNT=1
ESCROW_V2_NONCE=1
MPP_BUYER_IDENTITY=spendhub-owner

# Sprint 10 contract account. Testnet only; submit remains closed by default.
CONTRACT_ACCOUNT_ENABLED=false
CONTRACT_ACCOUNT_SUBMIT_ENABLED=false
CONTRACT_ACCOUNT_DEPLOY_ENABLED=false
CONTRACT_ACCOUNT_DEPLOY_ADMIN_TOKEN=replace-in-vercel-only
CONTRACT_ACCOUNT_WASM_HASH=6230e90601a82fd1afd8ae3dd59da55a4bc66d5e1fd4603996b1466f88c3c800
CONTRACT_ACCOUNT_NETWORK=stellar:testnet
CONTRACT_ACCOUNT_ID=C...
CONTRACT_ACCOUNT_MERCHANT=GAJK6AKXWGMRNRNZRLPZ5J7MUT4X7TZWHPEFEJJ5TL7V7XWPYKGG2CNV
CONTRACT_ACCOUNT_SESSION_PUBLIC_KEY=G...
CONTRACT_ACCOUNT_RELAYER_PUBLIC_KEY=GD2HWVSSD5I64HD5LCPCXW6NKSJLQRSL5V4OGBOIDRDCXM4VZRJBBKC6
CONTRACT_ACCOUNT_RELAYER_SECRET=replace-in-vercel-only
CONTRACT_ACCOUNT_RELAYER_IDENTITY=spendhub-relayer
CONTRACT_ACCOUNT_ENDPOINT=http://localhost:4179
CONTRACT_ACCOUNT_OWNER_IDENTITY=spendhub-owner
CONTRACT_ACCOUNT_OWNER_PUBLIC_KEY=G...
CONTRACT_ACCOUNT_ASSET_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
CONTRACT_ACCOUNT_FUND_AMOUNT=200000
CONTRACT_ACCOUNT_OWNER_PUBLIC_KEY_HEX=replace-after-passkey-registration
CONTRACT_ACCOUNT_CREDENTIAL_ID_HASH=replace-after-passkey-registration
CONTRACT_ACCOUNT_RP_ID_HASH=replace-after-passkey-registration
CONTRACT_ACCOUNT_ORIGIN_HASH=replace-after-passkey-registration

# Sprint 21-23 Stellar-first multichain control plane. All gates stay closed by default.
MULTICHAIN_ENABLED=false
BASE_X402_ENABLED=false
BASE_X402_MERCHANT_ADDRESS=0x...
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
X402_FACILITATOR_URL=https://x402.org/facilitator

# Public Privy application identifiers. Tokens, entropy and signing material are never server env vars.
PRIVY_APP_ID=replace-with-public-app-id
PRIVY_CLIENT_ID=replace-with-public-client-id

# Supervised CCTP Base Sepolia -> Stellar testnet bridge.
CCTP_ENABLED=false
CCTP_SUBMIT_ENABLED=false
CCTP_STELLAR_FORWARDER_CONTRACT_ID=C...
CCTP_STELLAR_DESTINATION=G...

# Registered for readiness only; code hard-disables settlement in this release.
AVALANCHE_SUBMIT_ENABLED=false
